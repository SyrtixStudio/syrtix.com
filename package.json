{
  "name": "syrtix-platform",
  "private": true,
  "version": "1.0.0",
  "packageManager": "pnpm@9.12.0",
  "scripts": {
    "dev": "pnpm run dev:frontend",
    "build": "pnpm --dir frontend install --frozen-lockfile && pnpm --dir frontend run build",
    "start": "pnpm --dir frontend run start",
    "dev:frontend": "pnpm --dir frontend run dev",
    "build:frontend": "pnpm --dir frontend run build",
    "preview:frontend": "pnpm --dir frontend run preview",
    "lint:frontend": "pnpm --dir frontend run lint",
    "dev:backend": "pnpm --dir backend run dev",
    "start:backend": "pnpm --dir backend run start",
    "install:all": "pnpm --dir frontend install && pnpm --dir backend install"
  }
}
