{
  "name": "syrtix-com",
  "private": true,
  "version": "1.0.0",
  "packageManager": "pnpm@9.12.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "node scripts/with-port.mjs vite preview --host 0.0.0.0 --port {PORT}",
    "start": "node scripts/with-port.mjs serve -s dist -l {PORT}",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --write \"src/**/*.{js,jsx,json,css}\"",
    "format:check": "prettier --check \"src/**/*.{js,jsx,json,css}\""
  },
  "dependencies": {
    "aos": "^2.3.4",
    "lucide-react": "^0.468.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-hook-form": "^7.71.1",
    "react-icons": "^5.5.0",
    "react-router-dom": "^7.1.1",
    "syrtix-platform": "file:.."
  },
  "devDependencies": {
    "@eslint/js": "^9.39.2",
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.39.2",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-import": "^2.32.0",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "globals": "^17.2.0",
    "postcss": "^8.4.49",
    "prettier": "^3.8.1",
    "serve": "^14.2.5",
    "tailwindcss": "^3.4.17",
    "vite": "^6.0.7"
  }
}
